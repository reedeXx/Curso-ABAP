projection;
strict ( 2 );
use draft;
define behavior for ZC_STUDENT_MPD alias Student
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Enrollment { create; with draft; }
}

define behavior for ZC_ENROLL_MPD alias Enrollment
{

  use update;
  use delete;

  use association _Student { with draft; }
}